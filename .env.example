# Dualys Website Environment Variables
# Copy this file to .env.local and fill in the values

# ============================================
# SITE CONFIGURATION
# ============================================
# Base URL for the site (used in sitemap, OG images, etc.)
NEXT_PUBLIC_SITE_URL=https://dualys.eu

# ============================================
# KEYSTATIC CMS (GitHub App for production)
# ============================================
# Create a GitHub App at https://github.com/settings/apps/new
# App name: dualys-keystatic-cms
# Callback URL: https://dualys.eu/api/keystatic/github/oauth/callback
# Permissions: Repository > Contents: Read & Write
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=
NEXT_PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=dualys-keystatic-cms

# Allowed GitHub usernames for CMS access (comma-separated)
# Leave empty to allow all users with repo access
KEYSTATIC_ALLOWED_USERS=InnovaBipi

# ============================================
# ANALYTICS (Future)
# ============================================
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ============================================
# HUBSPOT CRM (Contact Form)
# ============================================
# Create a Private App at HubSpot > Settings > Integrations > Private Apps
# Scopes: crm.objects.contacts.write
HUBSPOT_ACCESS_TOKEN=
# Portal ID for chat widget (public — used client-side)
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=148008397
